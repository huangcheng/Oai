# Seelie project clang-format config.
#
# Tuned to match the codebase's existing style — running this against
# src/ and tests/ should produce near-zero diff. Style is essentially
# Qt-canonical: 4-space indent, function braces on their own line,
# control-flow braces attached, pointer-to-the-name (`QObject *parent`).
#
# Run on a single file:    clang-format -i src/Foo.cpp
# Check formatting:        clang-format --dry-run --Werror src/Foo.cpp
# IDE integration is automatic for VS Code, Qt Creator, CLion when this
# file is at the project root.
---
Language: Cpp
Standard: c++17

# --- Indentation ----------------------------------------------------------
IndentWidth: 4
TabWidth: 4
UseTab: Never
ContinuationIndentWidth: 4
ConstructorInitializerIndentWidth: 4
NamespaceIndentation: None

# `public:` / `signals:` / `slots:` sit at column 0, class members at 4.
AccessModifierOffset: -4

# --- Line length ----------------------------------------------------------
# 100 strikes a balance: Qt class names and signal/slot connect lines often
# run long, but the codebase keeps almost everything under 100.
ColumnLimit: 100

# --- Braces ---------------------------------------------------------------
# The codebase mixes brace styles: function/class definitions get the brace
# on its own line (Allman), control flow gets attached braces and `} else {`
# / `} catch {` on the same line (K&R). Stroustrup gets close but breaks
# `} else {`, so spell it out with Custom.
BreakBeforeBraces: Custom
BraceWrapping:
  AfterCaseLabel: false
  AfterClass: true
  AfterControlStatement: Never
  AfterEnum: false
  AfterExternBlock: false
  AfterFunction: true
  AfterNamespace: false
  AfterStruct: true
  AfterUnion: false
  BeforeCatch: false      # `} catch (...) {` stays on one line
  BeforeElse: false       # `} else {` stays on one line
  BeforeLambdaBody: false
  BeforeWhile: false
  IndentBraces: false
  SplitEmptyFunction: true
  SplitEmptyRecord: true
  SplitEmptyNamespace: true

# --- Spacing & alignment --------------------------------------------------
PointerAlignment: Right
ReferenceAlignment: Right
DerivePointerAlignment: false
SpacesBeforeTrailingComments: 1

# The codebase uses `if (cond) return foo;` liberally as a guard pattern.
# Don't expand them.
AllowShortIfStatementsOnASingleLine: WithoutElse
AllowShortLoopsOnASingleLine: false
AllowShortCaseLabelsOnASingleLine: false
AllowShortBlocksOnASingleLine: Never
# Inline accessors like `qreal panelScale() const { return m_scale; }`
# are a Qt idiom — keep them on one line.
AllowShortFunctionsOnASingleLine: Inline
AllowShortLambdasOnASingleLine: All

# Don't pack function parameters or arguments onto fewer lines than the
# author chose. When a developer split parameters across lines, that's a
# signal — keep it.
BinPackParameters: false
BinPackArguments: false

# --- Initializer lists ----------------------------------------------------
# `: foo(x)`, one entry per line, comma-leading. Matches the constructors
# already in the codebase.
BreakConstructorInitializers: BeforeComma
PackConstructorInitializers: Never

# --- Includes -------------------------------------------------------------
# Don't reorder includes at all. Qt/macOS headers occasionally require a
# specific order: GLEW must come before any Qt GL header, Q_GLOBAL_STATIC
# can clash with Cocoa's <objc/runtime.h>, and the codebase already groups
# project headers / Qt headers / system headers manually.
SortIncludes: Never
IncludeBlocks: Preserve

# --- Comments & misc ------------------------------------------------------
ReflowComments: false   # don't rewrap our wrapped block comments
FixNamespaceComments: true
# Leave trailing comments where the author placed them — re-aligning to a
# tighter column produces a lot of noise on existing files for no real win.
AlignTrailingComments:
  Kind: Leave
  OverEmptyLines: 0
Cpp11BracedListStyle: true
KeepEmptyLines:
  AtEndOfFile: false
  AtStartOfBlock: false
  AtStartOfFile: false
EmptyLineBeforeAccessModifier: LogicalBlock
SeparateDefinitionBlocks: Leave

# --- Penalties -----------------------------------------------------------
# Discourage breaking inside parentheses; prefer to break the whole call.
PenaltyBreakAssignment: 100
PenaltyBreakBeforeFirstCallParameter: 50
PenaltyReturnTypeOnItsOwnLine: 200
