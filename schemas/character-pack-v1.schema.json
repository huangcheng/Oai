{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://seelie.cheng.im/schemas/character-pack-v1.json",
  "title": "Seelie Character Pack Manifest",
  "description": "Manifest format for Seelie character packs (.spk) — supports Lottie, sprite-sheet, and Live2D characters",
  "version": "1.0.0",
  "type": "object",
  "required": ["formatVersion", "id", "name", "author", "version", "character"],
  "properties": {
    "formatVersion": {
      "type": "string",
      "description": "Semantic version of the pack format",
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "description": "Unique reverse-domain identifier (e.g., 'com.example.mypet')",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9]*)*$"
    },
    "name": {
      "type": "string",
      "description": "Display name of the character pack (fallback / English)",
      "minLength": 1,
      "maxLength": 64
    },
    "nameLocalized": {
      "type": "object",
      "description": "Optional locale-keyed display names. Keys are POSIX locale codes (e.g. 'zh_CN', 'ja_JP'). The app picks an exact match, then a language-only prefix match (e.g. 'zh' matches 'zh_CN'), and falls back to `name`.",
      "patternProperties": {
        "^[a-z]{2,3}(_[A-Z]{2})?$": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        }
      },
      "additionalProperties": false
    },
    "author": {
      "type": "string",
      "description": "Creator name",
      "minLength": 1,
      "maxLength": 64
    },
    "version": {
      "type": "string",
      "description": "Pack version (semantic versioning)",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string",
      "description": "Short description of the character pack",
      "maxLength": 256
    },
    "preview": {
      "type": "string",
      "description": "Path to preview image (PNG or JPG)"
    },
    "tags": {
      "type": "array",
      "description": "Search/discovery tags",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 32
      },
      "maxItems": 10
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier"
    },
    "category": {
      "type": "string",
      "description": "Source/franchise grouping for the pack-picker menu (e.g. 'azur_lane', 'girls_frontline', 'konosuba', 'originals'). Free-form ASCII id; UI groups packs by this value. Optional — when absent, the runtime falls back to author-string heuristics for legacy packs.",
      "pattern": "^[a-z][a-z0-9_]*$",
      "maxLength": 32
    },
    "minAppVersion": {
      "type": "string",
      "description": "Minimum Seelie version required",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "character": {
      "$ref": "#/definitions/characterDef"
    },
    "idlePool": {
      "$ref": "#/definitions/idlePool"
    },
    "eventMap": {
      "$ref": "#/definitions/eventMap"
    },
    "effectTriggers": {
      "$ref": "#/definitions/effectTriggers"
    },
    "effects": {
      "$ref": "#/definitions/effectsDef"
    },
    "sounds": {
      "$ref": "#/definitions/soundsDef"
    }
  },
  "definitions": {
    "characterDef": {
      "type": "object",
      "description": "Character animation definitions",
      "oneOf": [
        {
          "required": ["type", "animations"],
          "properties": {
            "type": {
              "const": "lottie"
            },
            "directory": {
              "type": "string",
              "description": "Directory containing Lottie JSON files"
            }
          }
        },
        {
          "required": ["type", "spriteSheet", "frameWidth", "frameHeight", "animations"],
          "properties": {
            "type": {
              "const": "spriteSheet"
            },
            "spriteSheet": {
              "type": "string",
              "description": "Path to sprite sheet PNG"
            },
            "frameWidth": {
              "type": "integer",
              "description": "Frame width in pixels",
              "minimum": 1
            },
            "frameHeight": {
              "type": "integer",
              "description": "Frame height in pixels",
              "minimum": 1
            }
          }
        },
        {
          "required": ["type", "model"],
          "properties": {
            "type": {
              "const": "live2d"
            },
            "model": {
              "type": "string",
              "description": "Path to Live2D Cubism .model3.json"
            },
            "frameWidth": {
              "type": "integer",
              "description": "Render-target width in pixels",
              "minimum": 1
            },
            "frameHeight": {
              "type": "integer",
              "description": "Render-target height in pixels",
              "minimum": 1
            }
          }
        }
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["lottie", "spriteSheet", "live2d"],
          "description": "Animation engine type"
        },
        "directory": {
          "type": "string",
          "description": "Directory containing Lottie JSON files (for lottie type)"
        },
        "spriteSheet": {
          "type": "string",
          "description": "Path to sprite sheet PNG (for spriteSheet type)"
        },
        "model": {
          "type": "string",
          "description": "Path to .model3.json (for live2d type)"
        },
        "frameWidth": {
          "type": "integer",
          "description": "Frame/render width in pixels"
        },
        "frameHeight": {
          "type": "integer",
          "description": "Frame/render height in pixels"
        },
        "displayScale": {
          "type": "number",
          "description": "Multiplier applied to frameWidth/frameHeight when sizing the pet window. Defaults to 1.0 (native). Sprite packs can set e.g. 2.0 to render their low-res art larger next to 300x300 Live2D packs, trading sharpness for visual parity.",
          "exclusiveMinimum": 0,
          "default": 1.0
        },
        "animations": {
          "$ref": "#/definitions/animationMap"
        }
      }
    },
    "animationMap": {
      "type": "object",
      "description": "Map of animation name to animation definition",
      "additionalProperties": {
        "$ref": "#/definitions/animationDef"
      }
    },
    "animationDef": {
      "type": "object",
      "oneOf": [
        {
          "properties": {
            "type": {
              "const": "lottie"
            },
            "file": {
              "type": "string",
              "description": "Path to Lottie JSON file"
            }
          },
          "required": ["type", "file"]
        },
        {
          "properties": {
            "type": {
              "const": "sprite"
            },
            "frames": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/frameDef"
              },
              "minItems": 1
            }
          },
          "required": ["type", "frames"]
        }
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["lottie", "sprite"]
        },
        "file": {
          "type": "string",
          "description": "Path to Lottie JSON file (for lottie type)"
        },
        "frames": {
          "type": "array",
          "description": "Frame definitions (for sprite type)",
          "items": {
            "$ref": "#/definitions/frameDef"
          }
        },
        "loop": {
          "type": "boolean",
          "description": "Whether animation loops",
          "default": false
        },
        "priority": {
          "type": "string",
          "enum": ["high", "normal"],
          "description": "Animation priority",
          "default": "normal"
        },
        "effect": {
          "type": "string",
          "description": "Effect to trigger on animation start"
        },
        "sound": {
          "type": "string",
          "description": "Sound to play on animation start"
        }
      }
    },
    "frameDef": {
      "type": "object",
      "description": "Single animation frame definition",
      "oneOf": [
        {
          "properties": {
            "col": {
              "type": "integer",
              "description": "Column in sprite sheet grid",
              "minimum": 0
            },
            "row": {
              "type": "integer",
              "description": "Row in sprite sheet grid",
              "minimum": 0
            }
          },
          "required": ["col", "row"]
        },
        {
          "properties": {
            "x": {
              "type": "integer",
              "description": "X position in sprite sheet",
              "minimum": 0
            },
            "y": {
              "type": "integer",
              "description": "Y position in sprite sheet",
              "minimum": 0
            },
            "w": {
              "type": "integer",
              "description": "Frame width",
              "minimum": 1
            },
            "h": {
              "type": "integer",
              "description": "Frame height",
              "minimum": 1
            }
          },
          "required": ["x", "y", "w", "h"]
        }
      ],
      "properties": {
        "col": {
          "type": "integer",
          "description": "Column in sprite sheet grid"
        },
        "row": {
          "type": "integer",
          "description": "Row in sprite sheet grid"
        },
        "x": {
          "type": "integer",
          "description": "X position in sprite sheet"
        },
        "y": {
          "type": "integer",
          "description": "Y position in sprite sheet"
        },
        "w": {
          "type": "integer",
          "description": "Frame width"
        },
        "h": {
          "type": "integer",
          "description": "Frame height"
        },
        "duration": {
          "type": "integer",
          "description": "Frame duration in milliseconds",
          "minimum": 1
        }
      },
      "required": ["duration"]
    },
    "idlePool": {
      "type": "array",
      "description": "Weighted list of idle animations",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Animation name"
          },
          "weight": {
            "type": "integer",
            "description": "Selection weight (higher = more likely)",
            "minimum": 1
          }
        },
        "required": ["name", "weight"]
      }
    },
    "eventMap": {
      "type": "object",
      "description": "Map of canonical event name to animation name",
      "additionalProperties": {
        "type": "string"
      }
    },
    "effectTriggers": {
      "type": "object",
      "description": "Map of animation name to effect name",
      "additionalProperties": {
        "type": "string"
      }
    },
    "effectsDef": {
      "type": "object",
      "description": "Effects configuration",
      "properties": {
        "directory": {
          "type": "string",
          "description": "Directory containing Lottie effect files"
        }
      }
    },
    "soundsDef": {
      "type": "object",
      "description": "Sounds configuration",
      "properties": {
        "directory": {
          "type": "string",
          "description": "Directory containing sound files"
        }
      }
    }
  }
}
