# This file is used to ignore files which are generated
# ----------------------------------------------------------------------------

*~
*.autosave
*.a
*.core
*.moc
*.o
*.obj
*.orig
*.rej
*.so
*.so.*
*_pch.h.cpp
*_resource.rc
*.qm
.#*
*.*#
core
!core/
tags
.DS_Store
.directory
*.debug
Makefile*
*.prl
*.app
moc_*.cpp
ui_*.h
qrc_*.cpp
Thumbs.db
*.res
*.rc

# Installer staging — populated by `cmake --build . --target package_installer`
# (qt deploy + opks). Build output, not source.
installer/packages/*/data/

# Upstream Live2D community archive (~16 GB). Not a submodule — opt-in clone:
#   git clone https://github.com/Eikanya/Live2d-model thirdparty/upstream-live2d --depth=1
# See CONTRIBUTING.md for the full import workflow.
/thirdparty/upstream-live2d/

# Generated from .in templates by configure_file; track only the templates.
installer/config.xml
installer/packages/*/meta/package.xml

# Imported character packs are tracked in-tree (mirrors upstream Eikanya/Live2d-model).
# Re-importable locally via:
#   git clone https://github.com/Eikanya/Live2d-model thirdparty/upstream-live2d --depth=1
#   cmake --build build --target import_packs
/.qmake.cache
/.qmake.stash

# qtcreator generated files
*.pro.user*
*.qbs.user*
CMakeLists.txt.user*

# xemacs temporary files
*.flc

# Vim temporary files
.*.swp

# Visual Studio generated files
*.ib_pdb_index
*.idb
*.ilk
*.pdb
*.sln
*.suo
*.vcproj
*vcproj.*.*.user
*.ncb
*.sdf
*.opensdf
*.vcxproj
*vcxproj.*

# MinGW generated files
*.Debug
*.Release

# Python byte code
*.pyc

# Binaries
# --------
*.dll
*.exe

# Directories with generated files
.moc/
.obj/
.pch/
.rcc/
.uic/
/build*/
Testing/

# Claude Code: user-specific files only. Shared tooling (skills/, commands/,
# agents/) is tracked so the project workflow travels with the repo.
.claude/settings.local.json
.claude/local/
compile_commands.json

# Local IDE / session state (tmux-ide sidecar, machine-specific yml)
.tmux-ide/
ide.yml
