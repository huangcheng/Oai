{
  "hooks": {
    "PreToolUse": {
      "command": "@eastlake/clippy-gateway --source codex --event tool.before",
      "async": true
    },
    "PostToolUse": {
      "command": "@eastlake/clippy-gateway --source codex --event tool.after",
      "async": true
    },
    "SessionStart": {
      "command": "@eastlake/clippy-gateway --source codex --event session.start",
      "async": true
    },
    "Stop": {
      "command": "@eastlake/clippy-gateway --source codex --event session.idle",
      "async": true
    },
    "UserPromptSubmit": {
      "command": "@eastlake/clippy-gateway --source codex --event prompt.submitted",
      "async": true
    },
    "PermissionRequest": {
      "command": "@eastlake/clippy-gateway --source codex --event permission.requested",
      "async": true
    }
  }
}
