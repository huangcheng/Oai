{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
    {jsx, "3.1.0"}
]}.

{shell, [
    {config, "config/sys.config"},
    {apps, [server]}
]}.

{relx, [
    {release, {server, "0.1.0"}, [server, sasl]},
    {mode, dev},
    {sys_config, "config/sys.config"},
    {vm_args, "config/vm.args"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {mode, prod},
            {include_src, false},
            {include_erts, true}
        ]}
    ]}
]}.
