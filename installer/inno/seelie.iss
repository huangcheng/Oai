; Seelie Desktop Pet — Inno Setup script
; Compile with: ISCC.exe /DSrcDir=<staging> /DAppVersion=<x.y.z> seelie.iss
;
; Layout assumptions:
;   {#SrcDir} contains the same flat tree QtIFW's installer_stage produces:
;       Seelie.exe, Qt6*.dll, Live2DCubismCore.dll, plugins/, assets/...
;   This is generated by `cmake --build build --target installer_stage` and
;   ends up at installer/packages/im.cheng.seelie.desktop/data/.
;
;   {#ProjectRoot} is the repo root — used to find LICENSE, the .ico, and
;   to write the output .exe into build/. Passed in by build_inno.py.

#ifndef SrcDir
  #error SrcDir not defined. Pass /DSrcDir=<path> to ISCC.
#endif
#ifndef ProjectRoot
  #error ProjectRoot not defined. Pass /DProjectRoot=<path> to ISCC.
#endif
#ifndef AppVersion
  #define AppVersion "1.0.0"
#endif

#define AppName "Seelie"
#define AppPublisher "HUANG Cheng"
#define AppURL "https://github.com/huangcheng/Seelie"
#define AppExeName "Seelie.exe"
#define AppId "{{E3F8C7B4-9A2D-4E5F-B1C8-3D7F2A8E9C4B}"

[Setup]
AppId={#AppId}
AppName={#AppName}
AppVersion={#AppVersion}
AppVerName={#AppName} {#AppVersion}
AppPublisher={#AppPublisher}
AppPublisherURL={#AppURL}
AppSupportURL={#AppURL}/issues
AppUpdatesURL={#AppURL}/releases
DefaultDirName={autopf}\{#AppName}
DefaultGroupName={#AppName}
DisableProgramGroupPage=yes
LicenseFile={#ProjectRoot}\LICENSE
OutputDir={#ProjectRoot}\build
OutputBaseFilename=SeelieSetup-{#AppVersion}
SetupIconFile={#ProjectRoot}\assets\seelie.ico
UninstallDisplayIcon={app}\{#AppExeName}
Compression=lzma2/ultra64
SolidCompression=yes
WizardStyle=modern

; Branding — wizard images shown on Welcome/Finish + every other page
WizardImageFile=branding\wizard-image.bmp,branding\wizard-image@2x.bmp
WizardSmallImageFile=branding\wizard-small-image.bmp,branding\wizard-small-image@2x.bmp
WizardImageStretch=yes
WizardImageAlphaFormat=defined

; Per-user OR per-machine — user picks at install time. No code; Inno's
; built-in dialog handles everything. Big UX win over QtIFW.
PrivilegesRequired=lowest
PrivilegesRequiredOverridesAllowed=dialog

ArchitecturesAllowed=x64compatible
ArchitecturesInstallIn64BitMode=x64compatible
MinVersion=10.0.17763
ChangesAssociations=no

[Languages]
; First-listed is the default. Inno auto-shows a language picker dialog at
; startup whenever 2+ languages are listed, before any wizard page. Users
; pick once; the entire wizard chrome and our [Messages] entries flip
; consistently. No process restart needed (Inno's i18n is single-process).
;
; ChineseSimplified.isl is vendored locally — Inno Setup 6.7.1 ships only
; ~28 official languages; Chinese is community-maintained and lives at
; jrsoftware/issrc:Files/Languages/Unofficial/. We pin a copy here.
Name: "english"; MessagesFile: "compiler:Default.isl"
Name: "schinese"; MessagesFile: "ChineseSimplified.isl"

[Messages]
; Override a few wizard chrome strings with product-specific phrasing.
english.WelcomeLabel2=This will install [name/ver] on your computer.%n%nA tiny desktop pet that reacts to your AI coding tool events. Lightweight, frameless, always-on-top.%n%nIt is recommended that you close all other applications before continuing.
schinese.WelcomeLabel2=即将在您的电脑上安装 [name/ver]。%n%nSeelie 是一个轻量级桌面宠物，会响应您的 AI 编程工具事件。无边框、置顶显示，约 10MB 内存占用。%n%n建议您在继续之前关闭其他正在运行的程序。

[Tasks]
Name: "desktopicon"; Description: "{cm:CreateDesktopIcon}"; GroupDescription: "{cm:AdditionalIcons}"; Flags: unchecked
Name: "autostart"; Description: "{cm:AutoStartTask}"; GroupDescription: "{cm:AdditionalIcons}"; Flags: unchecked

[CustomMessages]
english.AutoStartTask=Launch Seelie automatically at Windows startup
schinese.AutoStartTask=开机时自动启动 Seelie
english.LaunchAfterInstall=Launch {#AppName}
schinese.LaunchAfterInstall=立即启动 {#AppName}

[Files]
; All app payload from the staged dir, recursed. recursesubdirs + ignoreversion
; means we don't re-version-check Qt DLLs (always overwrite for upgrades).
Source: "{#SrcDir}\*"; DestDir: "{app}"; Flags: ignoreversion recursesubdirs createallsubdirs

[Icons]
Name: "{group}\{#AppName}"; Filename: "{app}\{#AppExeName}"
Name: "{group}\{cm:UninstallProgram,{#AppName}}"; Filename: "{uninstallexe}"
Name: "{autodesktop}\{#AppName}"; Filename: "{app}\{#AppExeName}"; Tasks: desktopicon

[Registry]
; Optional auto-start — only created if the user ticked the task. Per-user
; HKCU\...\Run (no admin needed). Removed on uninstall via uninsdeletevalue.
Root: HKCU; Subkey: "Software\Microsoft\Windows\CurrentVersion\Run"; \
    ValueType: string; ValueName: "{#AppName}"; ValueData: """{app}\{#AppExeName}"""; \
    Tasks: autostart; Flags: uninsdeletevalue

[Run]
; Optional launch-after-install (the standard Inno checkbox on the Finish page).
Filename: "{app}\{#AppExeName}"; Description: "{cm:LaunchAfterInstall}"; \
    Flags: nowait postinstall skipifsilent
