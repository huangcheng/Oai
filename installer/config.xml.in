<?xml version="1.0" encoding="UTF-8"?>
<Installer>
    <Name>Seelie</Name>
    <Version>@PROJECT_VERSION@</Version>

    <Title>Seelie Desktop Pet</Title>
    <Publisher>HUANG Cheng</Publisher>
    <ProductUrl>https://github.com/huangcheng/Seelie</ProductUrl>

    <WizardStyle>Modern</WizardStyle>

    <StartMenuDir>Seelie</StartMenuDir>
    <!-- Default install location. Resolves to C:\Program Files\Seelie on
         64-bit Windows, /Applications/Seelie on macOS, /opt/Seelie on Linux.
         Users can change it via the wizard's folder picker page. -->
    <TargetDir>@IFW_TARGET_DIR@</TargetDir>

    <AllowNonAsciiCharacters>true</AllowNonAsciiCharacters>

    <!--
        Qt IFW ships built-in chrome translations (Next/Cancel/...) for many
        languages; they auto-load from the user's locale.  We additionally
        bundle our own .qm files so package-level qsTr() strings compiled from
        translations/*.ts get picked up too.  The .qm files are produced by
        `lrelease` at build time (see top-level CMakeLists.txt).

        English is listed explicitly so the installer can be forced to run in
        English on a Chinese system (e.g., for testing or user preference).
    -->
    <Translations>
        <Translation>seelie_installer_en.qm</Translation>
        <Translation>seelie_installer_zh_CN.qm</Translation>
    </Translations>
</Installer>
