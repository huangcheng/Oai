<?xml version="1.0" encoding="UTF-8"?>
<Installer>
    <Name>Oai</Name>
    <Version>@PROJECT_VERSION@</Version>

    <Title>Oai Desktop Pet</Title>
    <Publisher>HUANG Cheng</Publisher>
    <ProductUrl>https://github.com/eastlake-cheng/oai</ProductUrl>

    <WizardStyle>Modern</WizardStyle>

    <StartMenuDir>Oai</StartMenuDir>
    <!-- Install location is pinned to @ApplicationsDir@/Oai
         (C:\Program Files\Oai on 64-bit Windows, /Applications/Oai on
         macOS, /opt/Oai on Linux). The wizard's folder picker is hidden
         in installscript.qs via setDefaultPageVisible(TargetDirectory). -->
    <TargetDir>@ApplicationsDir@/Oai</TargetDir>

    <AllowNonAsciiCharacters>true</AllowNonAsciiCharacters>

    <!--
        Qt IFW ships built-in chrome translations (Next/Cancel/...) for many
        languages including zh_CN; they auto-load from the user's locale.
        We additionally bundle our own .qm so package-level qsTr() strings
        compiled from translations/*.ts get picked up too. The .qm files are
        produced by `lrelease` at build time (see top-level CMakeLists.txt).
    -->
    <Translations>
        <Translation>oai_installer_zh_CN.qm</Translation>
    </Translations>
</Installer>
