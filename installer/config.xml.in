<?xml version="1.0" encoding="UTF-8"?>
<Installer>
    <Name>Seelie</Name>
    <Version>@PROJECT_VERSION@</Version>

    <Title>Seelie Desktop Pet</Title>
    <Publisher>HUANG Cheng</Publisher>
    <ProductUrl>https://github.com/huangcheng/Seelie</ProductUrl>

    <WizardStyle>Modern</WizardStyle>

    <StartMenuDir>Seelie</StartMenuDir>
    <!-- Default install location. Resolves to C:\Program Files\Seelie on
         64-bit Windows, /Applications/Seelie on macOS, /opt/Seelie on Linux.
         Users can change it via the wizard's folder picker page. -->
    <TargetDir>@IFW_TARGET_DIR@</TargetDir>

    <AllowNonAsciiCharacters>true</AllowNonAsciiCharacters>

    <!-- Installer is English-only for v1.0.0. Qt IFW's bundled chrome
         translations cover Next/Cancel/etc. for many languages, but its
         zh_CN coverage is incomplete in 4.11. Re-introduce localized
         translations once we can ship a complete chrome translation. -->
    <Translations>
        <Translation>seelie_installer_en.qm</Translation>
    </Translations>
</Installer>
