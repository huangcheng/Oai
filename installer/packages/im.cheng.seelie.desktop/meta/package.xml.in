<?xml version="1.0" encoding="UTF-8"?>
<Package>
    <DisplayName>Seelie Desktop Pet</DisplayName>

    <Description>A native Qt6/C++ desktop pet that reacts to AI coding tool events.</Description>

    <Version>@PROJECT_VERSION@</Version>
    <ReleaseDate>@SEELIE_RELEASE_DATE@</ReleaseDate>

    <Default>true</Default>
    <Essential>true</Essential>
    <ForcedInstallation>true</ForcedInstallation>

    <Licenses>
        <License name="MIT License" file="license.txt" />
    </Licenses>

    <Script>installscript.qs</Script>
</Package>
